# Indiciário — variáveis de ambiente de desenvolvimento
# Copie para .env e preencha apenas o que for usar no ambiente local.

# Ambiente
INDICIARIO_ENV=dev
INDICIARIO_DEBUG=false

# LLM / geração de blueprint
# Use apenas um provedor por vez no MVP.
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Saídas locais
OUTPUT_DIR=./output
EXAMPLES_DIR=./examples
TEMPLATES_DIR=./templates
FRAMEWORK_DIR=./framework

# Renderização
PDF_RENDERER=weasyprint
RENDER_SCREENSHOTS=false
SCREENSHOT_DPI=150

# Telegram — futuro fluxo comercial/operacional
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# Mercado Pago — futuro Pix/checkout
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=
MERCADO_PAGO_SUCCESS_URL=
MERCADO_PAGO_FAILURE_URL=
MERCADO_PAGO_PENDING_URL=

# Banco de dados — não obrigatório no MVP documental
# Manter vazio enquanto o projeto estiver em Markdown/YAML/HTML/PDF.
DATABASE_URL=
